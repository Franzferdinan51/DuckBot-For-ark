{
  "llm": {
    "provider": "openrouter",  // openrouter, anthropic, openai, gemini, lmstudio, minimax, ollama
    "model": "anthropic/claude-3.5-sonnet",
    "api_key": "YOUR-API-KEY-HERE",
    // For lmstudio/ollama (local), api_key can be "local" or any value:
    // "provider": "lmstudio",
    // "model": "local-model",  // model name loaded in LM Studio
    // "api_key": "local",
    // "api_base": "http://localhost:1234"  // LM Studio default port
  },
  "auth": {
    "shared_secret": "change-this-to-a-random-secret-at-least-16-chars"
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8443,           // Game plugin WebSocket port
    "admin_port": 8444      // Desktop companion app WebSocket port (Ark-DuckBot-Desktop)
  },
  "ark": {
    "map": "TheIsland",
    "cluster_id": "",
    "wild_dino_alert_enabled": true,
    "wild_dino_alert_min_level": 30,
    "wild_dino_alert_species": ["Giganotosaurus", "Titanosaur", "Megalodon", "Tusoteuthis", "Rex", "Spino"],
    "tribe_member_auto_track": true,
    "tribe_dino_limit": 500,
    "ai_context_window": 50,
    "ai_personality": "helpful_assistant"
  }
}